# Database Configuration
# For SQLite (default, development):
DATABASE_URL=sqlite+aiosqlite:////app/data/baseball.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/baseball_db

# SQLite-specific path (ignored if using PostgreSQL)
SQLITE_DATABASE_PATH=/app/data/baseball.db

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Application Settings
DEBUG=False
APP_NAME=NPB Baseball Statistics API
APP_VERSION=1.0.0
